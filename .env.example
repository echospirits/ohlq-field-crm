# Use a pooled Postgres connection for serverless runtime on Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ohlq_crm?sslmode=require"

APP_BASE_URL="http://localhost:3000"

# Vercel Blob object storage for uploaded visit photos.
BLOB_READ_WRITE_TOKEN=""

# Weekly digest email delivery.
RESEND_API_KEY=""
EMAIL_FROM="Echo Field CRM <crm@example.com>"
CRON_SECRET=""

# OHLQ Annual Sales Summary export automation.
OHLQ_OPS_USERNAME=""
OHLQ_OPS_PASSWORD=""

# Optional for clean-browser/cloud runs if Microsoft allows non-interactive auth.
OHLQ_MICROSOFT_USERNAME=""
OHLQ_MICROSOFT_PASSWORD=""

# Optional backfill override. Defaults to yesterday in America/New_York.
OHLQ_REPORT_DATE=""

# Optional raw row retention window for OHLQ report fact tables. Defaults to 30 days.
OHLQ_REPORT_RETENTION_DAYS="30"

# Optional cron catch-up controls. Defaults import up to 2 missing report dates across a 3-day window.
OHLQ_CRON_CATCHUP_DAYS="3"
OHLQ_CRON_MAX_REPORT_DATES="2"

# Optional: lets the Data Status manual import button queue the GitHub Actions cloud runner.
GITHUB_ACTIONS_DISPATCH_TOKEN=""
GITHUB_ACTIONS_REPOSITORY="echospirits/ohlq-field-crm"
GITHUB_ACTIONS_REF="main"
GITHUB_ACTIONS_OHLQ_WORKFLOW_ID="ohlq-annual-sales.yml"

# Optional local output path. Defaults to output/ohlq-downloads.
OHLQ_DOWNLOAD_DIR=""
OHLQ_HEADLESS=""
OHLQ_BROWSER_CHANNEL=""
OHLQ_USE_SERVERLESS_CHROMIUM=""

# Optional future integrations
EVENTBRITE_TOKEN=""
EVENTBRITE_ORGANIZATION_ID=""
NEXT_PUBLIC_APP_NAME="Echo Spirits Distilling Co."
