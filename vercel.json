{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/admin/ohlq-manual-import/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/ohlq-annual-sales/route.ts": {
      "maxDuration": 800
    }
  },
  "crons": [
    {
      "path": "/api/cron/ohlq-annual-sales",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 13 * * 5"
    }
  ]
}
