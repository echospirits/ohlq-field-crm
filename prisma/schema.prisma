generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  LIQUOR_AGENCY
  BAR_RESTAURANT
  CHAIN_GROUP
  OTHER
}

enum AlertStatus {
  OPEN
  SNOOZED
  DISMISSED
  RESOLVED
}

enum PhotoType {
  SHELF
  DISPLAY
  MENU
  BACK_BAR
  COMPETITOR
  OTHER
}

enum EventSource {
  MANUAL
  EVENTBRITE
  GOOGLE_SHEET
}

enum WorklistStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorklistSource {
  MANUAL
  VISIT_FOLLOW_UP
  OHLQ_WHOLESALE_REACTIVATION
}

enum WorklistCategory {
  AGENCY
  WHOLESALE
  GENERAL
}

enum UserRole {
  ADMIN
  USER
}

enum WeeklyDigestType {
  USER_WEEKLY
  ADMIN_WEEKLY
}

enum WeeklyDigestStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum MenuPlacementType {
  COCKTAIL_MENU
  MENU_FEATURE
  HAPPY_HOUR
  TABLE_TENT
  QR_DIGITAL
  BACK_BAR
  OTHER
}

enum MenuPlacementStatus {
  PROMISED
  LIVE
  PAUSED
  ENDED
  LOST
}

enum MenuPlacementSource {
  MANUAL
  VISIT
  PHOTO
  ACCOUNT_REVIEW
  IMPORT
}

enum OhlqReportDataSource {
  ANNUAL_SALES_SUMMARY
  ANNUAL_SALES_SUMMARY_BY_WHOLESALE
}

enum OhlqReportRunStatus {
  RUNNING
  COMPLETED
  ERRORED
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  firstName                String?
  lastName                 String?
  name                     String?
  phone                    String?
  passwordHash             String?
  role                     UserRole           @default(USER)
  isActive                 Boolean            @default(true)
  image                    String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  sessions                 UserSession[]
  createdWholesaleAccounts WholesaleAccount[] @relation("WholesaleAccountCreatedBy")
  createdLocationContacts  LocationContact[]  @relation("LocationContactCreatedBy")
  createdLoggedVisits      LoggedVisit[]      @relation("LoggedVisitCreatedBy")
  createdVisitPhotos       VisitPhoto[]       @relation("VisitPhotoCreatedBy")
  createdWorklistItems     WorklistItem[]     @relation("WorklistItemCreatedBy")
  createdTags              Tag[]              @relation("TagCreatedBy")
  createdLocationTags      LocationTag[]      @relation("LocationTagCreatedBy")
  createdRecipes           Recipe[]           @relation("RecipeCreatedBy")
  updatedRecipes           Recipe[]           @relation("RecipeUpdatedBy")
  createdRecipeSuggestions RecipeSuggestion[] @relation("RecipeSuggestionCreatedBy")
  assignedMenuPlacements   MenuPlacement[]    @relation("MenuPlacementAssignedTo")
  createdMenuPlacements    MenuPlacement[]    @relation("MenuPlacementCreatedBy")
  updatedMenuPlacements    MenuPlacement[]    @relation("MenuPlacementUpdatedBy")
  weeklyDigestLogs         WeeklyDigestLog[]  @relation("WeeklyDigestRecipient")
  assignedWorklistItems    WorklistItem[]     @relation("WorklistItemAssignedTo")
  completedWorklistItems   WorklistItem[]     @relation("WorklistItemCompletedBy")
  cancelledWorklistItems   WorklistItem[]     @relation("WorklistItemCancelledBy")

  @@index([role])
  @@index([isActive])
}

model WeeklyDigestLog {
  id                String             @id @default(cuid())
  digestType        WeeklyDigestType
  recipientUserId   String?
  recipientEmail    String
  periodStart       DateTime
  periodEnd         DateTime
  scheduledFor      DateTime
  runAt             DateTime?
  status            WeeklyDigestStatus @default(PENDING)
  attemptCount      Int                @default(0)
  providerMessageId String?
  errorMessage      String?
  lastSkippedAt     DateTime?
  lastSkipReason    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  recipientUser     User?              @relation("WeeklyDigestRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@unique([digestType, recipientEmail, periodStart, periodEnd])
  @@index([digestType])
  @@index([recipientUserId])
  @@index([recipientEmail])
  @@index([periodStart, periodEnd])
  @@index([scheduledFor])
  @@index([status])
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginThrottle {
  id            String    @id @default(cuid())
  identifier    String    @unique
  failedCount   Int       @default(0)
  lockedUntil   DateTime?
  lastAttemptAt DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([lockedUntil])
}

model Account {
  id                  String            @id @default(cuid())
  externalId          String?           @unique
  agencyId            String?           @unique
  agencyRefId         String?
  licenseeId          String?           @unique
  type                AccountType
  name                String
  address             String?
  city                String?
  county              String?
  state               String?           @default("OH")
  zip                 String?
  phone               String?
  d8Permit            Boolean           @default(false)
  ownership           String?
  districtId          String?
  warehouse           String?
  orderDay            String?
  orderWeek           String?
  deliveryDay         String?
  primaryContact      String?
  primaryContactPhone String?
  wholesaleStatus     String?
  ownerUserId         String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tags                AccountTag[]
  notes               Note[]
  photos              Photo[]
  tasks               Task[]
  alerts              Alert[]
  salesFacts          SalesFact[]
  inventoryFacts      InventoryFact[]
  visits              Visit[]
  menuPlacements      MenuPlacement[]
  officialWholesale   WholesaleAccount? @relation("OfficialWholesaleAccount")
}

model Sku {
  id             String          @id @default(cuid())
  itemCode       String          @unique
  brand          String?
  name           String
  category       String?
  active         Boolean         @default(true)
  recipes        Recipe[]
  salesFacts     SalesFact[]
  inventoryFacts InventoryFact[]
}

model Tag {
  id              String        @id @default(cuid())
  name            String        @unique
  color           String?
  description     String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        AccountTag[]
  locationTags    LocationTag[]
  createdByUser   User?         @relation("TagCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
}

model AccountTag {
  accountId String
  tagId     String
  reason    String?
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([accountId, tagId])
}

model SalesFact {
  id               String   @id @default(cuid())
  accountId        String
  skuId            String
  periodMonth      DateTime
  retailBottles    Int      @default(0)
  retailAmount     Decimal  @default(0)
  wholesaleBottles Int      @default(0)
  wholesaleAmount  Decimal  @default(0)
  account          Account  @relation(fields: [accountId], references: [id])
  sku              Sku      @relation(fields: [skuId], references: [id])

  @@unique([accountId, skuId, periodMonth])
}

model InventoryFact {
  id               String    @id @default(cuid())
  accountId        String
  skuId            String
  snapshotDate     DateTime  @default(now())
  coverageStatus   String?
  minFlag          Boolean   @default(false)
  inventoryBottles Int       @default(0)
  sales12MoBottles Int       @default(0)
  lastArrivalDate  DateTime?
  account          Account   @relation(fields: [accountId], references: [id])
  sku              Sku       @relation(fields: [skuId], references: [id])

  @@unique([accountId, skuId, snapshotDate])
}

model OhlqAnnualSalesRow {
  reportDate           DateTime @db.Date
  agencyId             String
  vendor               String
  brand                String
  retailBottlesSold    Int      @default(0)
  wholesaleBottlesSold Int      @default(0)

  @@id([reportDate, agencyId, vendor, brand])
  @@index([agencyId, vendor, reportDate, brand])
}

model OhlqAnnualSalesByWholesaleRow {
  reportDate           DateTime @db.Date
  agencyId             String
  vendor               String
  brand                String
  permitNumber         String
  wholesaleBottlesSold Int      @default(0)

  @@id([reportDate, agencyId, vendor, brand, permitNumber])
  @@index([permitNumber, reportDate])
  @@index([permitNumber, vendor, reportDate, brand])
}

model OhlqBrandMasterItem {
  itemCode           String   @id
  name               String
  vendor             String?
  broker             String?
  category           String?
  purchaseUnitSymbol String?
  productVolume      Decimal?
  retailPrice        Decimal?
  wholesalePrice     Decimal?
  solItemStatusCode  String?
  bottleLimit        Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([name])
  @@index([vendor])
  @@index([category])
}

model OhlqReportImportStatus {
  id               String               @id @default(cuid())
  dataSource       OhlqReportDataSource
  reportDate       DateTime             @db.Date
  status           OhlqReportRunStatus
  rowCount         Int                  @default(0)
  parsedRows       Int                  @default(0)
  skippedRows      Int                  @default(0)
  replacedRows     Int                  @default(0)
  sizeBytes        Int                  @default(0)
  filename         String?
  startedAt        DateTime             @default(now())
  completedAt      DateTime?
  lastSuccessfulAt DateTime?
  errorMessage     String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([dataSource, reportDate])
  @@index([dataSource])
  @@index([reportDate])
  @@index([status])
  @@index([lastSuccessfulAt])
}

model Alert {
  id           String      @id @default(cuid())
  accountId    String
  skuId        String?
  type         String
  title        String
  detail       String?
  status       AlertStatus @default(OPEN)
  dueDate      DateTime?
  snoozedUntil DateTime?
  resolvedAt   DateTime?
  dismissedAt  DateTime?
  account      Account     @relation(fields: [accountId], references: [id])
  notes        Note[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  accountId String
  alertId   String?
  body      String
  createdBy String?
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id])
  alert     Alert?   @relation(fields: [alertId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  accountId   String
  title       String
  dueDate     DateTime?
  completedAt DateTime?
  ownerUserId String?
  account     Account   @relation(fields: [accountId], references: [id])
}

model Visit {
  id             String          @id @default(cuid())
  accountId      String
  visitDate      DateTime        @default(now())
  summary        String?
  createdBy      String?
  account        Account         @relation(fields: [accountId], references: [id])
  photos         Photo[]
  menuPlacements MenuPlacement[]
}

model Photo {
  id                 String         @id @default(cuid())
  accountId          String
  visitId            String?
  type               PhotoType
  url                String
  caption            String?
  takenAt            DateTime       @default(now())
  account            Account        @relation(fields: [accountId], references: [id])
  visit              Visit?         @relation(fields: [visitId], references: [id])
  menuPlacementProof MenuPlacement? @relation("MenuPlacementProofPhoto")
}

model MenuPlacement {
  id                 String              @id @default(cuid())
  accountId          String
  wholesaleAccountId String?
  visitId            String?
  proofPhotoId       String?             @unique
  product            String
  menuItemName       String
  placementType      MenuPlacementType   @default(COCKTAIL_MENU)
  status             MenuPlacementStatus @default(PROMISED)
  source             MenuPlacementSource @default(MANUAL)
  proofUrl           String?
  proofStorageKey    String?
  proofContentType   String?
  proofSizeBytes     Int?
  firstSeenAt        DateTime?
  lastVerifiedAt     DateTime?
  expectedEndAt      DateTime?
  notes              String?
  assignedToUserId   String?
  createdByUserId    String?
  updatedByUserId    String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  account            Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  wholesaleAccount   WholesaleAccount?   @relation(fields: [wholesaleAccountId], references: [id], onDelete: SetNull)
  visit              Visit?              @relation(fields: [visitId], references: [id], onDelete: SetNull)
  proofPhoto         Photo?              @relation("MenuPlacementProofPhoto", fields: [proofPhotoId], references: [id], onDelete: SetNull)
  assignedToUser     User?               @relation("MenuPlacementAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdByUser      User?               @relation("MenuPlacementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser      User?               @relation("MenuPlacementUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([wholesaleAccountId])
  @@index([status])
  @@index([placementType])
  @@index([source])
  @@index([firstSeenAt])
  @@index([lastVerifiedAt])
  @@index([expectedEndAt])
  @@index([assignedToUserId])
}

model EventShift {
  id             String      @id @default(cuid())
  source         EventSource @default(MANUAL)
  externalId     String?
  title          String
  startsAt       DateTime
  endsAt         DateTime?
  location       String?
  accountId      String?
  assignedUserId String?
  status         String      @default("open")
  createdAt      DateTime    @default(now())
}

model Recipe {
  id                String             @id @default(cuid())
  name              String
  primarySpirit     String?
  preparation       String?
  glassware         String?
  sourceAttribution String?
  fitsNeed          String?
  complexity        String?
  recipeText        String             @default("")
  ingredients       Json               @default("[]")
  instructions      String             @default("")
  garnish           String?
  season            String?
  flavorProfile     String?
  notes             String?
  photoUrl          String?
  photoStorageKey   String?
  photoContentType  String?
  photoSizeBytes    Int?
  photoCaption      String?
  importSource      String?
  importKey         String?            @unique
  skuId             String?
  createdByUserId   String?
  updatedByUserId   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sku               Sku?               @relation(fields: [skuId], references: [id])
  createdByUser     User?              @relation("RecipeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser     User?              @relation("RecipeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  suggestions       RecipeSuggestion[]

  @@index([name])
  @@index([primarySpirit])
  @@index([complexity])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model RecipeSuggestion {
  id                 String           @id @default(cuid())
  recipeId           String
  wholesaleAccountId String
  note               String?
  suggestedAt        DateTime         @default(now())
  createdByUserId    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  recipe             Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  wholesaleAccount   WholesaleAccount @relation(fields: [wholesaleAccountId], references: [id], onDelete: Cascade)
  createdByUser      User?            @relation("RecipeSuggestionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([recipeId, wholesaleAccountId])
  @@index([recipeId])
  @@index([wholesaleAccountId])
  @@index([suggestedAt])
  @@index([createdByUserId])
}

model Agency {
  id                  String        @id @default(cuid())
  agencyId            String        @unique
  name                String
  address             String?
  city                String?
  county              String?
  state               String?       @default("OH")
  zip                 String?
  phone               String?
  d8Permit            Boolean       @default(false)
  warehouse           String?
  orderDay            String?
  orderWeek           String?
  deliveryDay         String?
  primaryContact      String?
  primaryContactPhone String?
  wholesaleStatus     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  tags                LocationTag[] @relation("AgencyLocationTags")
}

model WholesaleAccount {
  id                String             @id @default(cuid())
  licenseeId        String             @unique
  officialAccountId String?            @unique
  isActive          Boolean            @default(true)
  agencyId          String?
  ownership         String?
  name              String
  address           String?
  city              String?
  county            String?
  state             String?            @default("OH")
  zip               String?
  districtId        String?
  deliveryDay       String?
  phone             String?
  ohlqLastEchoPurchaseDate      DateTime? @db.Date
  ohlqLastEchoPurchaseItemCode  String?
  ohlqLastEchoPurchaseItemName  String?
  ohlqLastEchoPurchaseBottles   Int       @default(0)
  ohlqLastEchoPurchaseUpdatedAt DateTime?
  createdByUserId   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdByUser     User?              @relation("WholesaleAccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  officialAccount   Account?           @relation("OfficialWholesaleAccount", fields: [officialAccountId], references: [id], onDelete: SetNull)
  licenseeIds       WholesaleLicenseeId[]
  tags              LocationTag[]      @relation("WholesaleLocationTags")
  recipeSuggestions RecipeSuggestion[]
  menuPlacements    MenuPlacement[]

  @@index([createdByUserId])
  @@index([isActive])
  @@index([officialAccountId])
  @@index([ohlqLastEchoPurchaseDate])
}

model WholesaleLicenseeId {
  id                 String           @id @default(cuid())
  wholesaleAccountId String
  licenseeId         String           @unique
  isPrimary          Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  wholesaleAccount   WholesaleAccount @relation(fields: [wholesaleAccountId], references: [id], onDelete: Cascade)

  @@index([wholesaleAccountId])
  @@index([isPrimary])
}

model LocationTag {
  id                 String            @id @default(cuid())
  tagId              String
  agencyId           String?
  wholesaleAccountId String?
  note               String?
  createdByUserId    String?
  createdAt          DateTime          @default(now())
  tag                Tag               @relation(fields: [tagId], references: [id], onDelete: Cascade)
  agency             Agency?           @relation("AgencyLocationTags", fields: [agencyId], references: [id], onDelete: Cascade)
  wholesaleAccount   WholesaleAccount? @relation("WholesaleLocationTags", fields: [wholesaleAccountId], references: [id], onDelete: Cascade)
  createdByUser      User?             @relation("LocationTagCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([tagId, agencyId])
  @@unique([tagId, wholesaleAccountId])
  @@index([tagId])
  @@index([agencyId])
  @@index([wholesaleAccountId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model LocationContact {
  id                 String   @id @default(cuid())
  name               String
  role               String?
  phone              String?
  email              String?
  agencyId           String?
  wholesaleAccountId String?
  notes              String?
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdByUser      User?    @relation("LocationContactCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
}

model LoggedVisit {
  id                 String         @id @default(cuid())
  visitAt            DateTime       @default(now())
  locationType       String
  agencyId           String?
  wholesaleAccountId String?
  contactId          String?
  summary            String?
  outcomes           String?
  nextStep           String?
  followUpDate       DateTime?
  createdBy          String?
  createdByUserId    String?
  createdAt          DateTime       @default(now())
  createdByUser      User?          @relation("LoggedVisitCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  photos             VisitPhoto[]
  worklistItems      WorklistItem[]

  @@index([createdByUserId])
  @@index([locationType, agencyId, visitAt])
  @@index([locationType, wholesaleAccountId, visitAt])
}

model VisitPhoto {
  id              String      @id @default(cuid())
  loggedVisitId   String
  type            PhotoType
  url             String
  storageKey      String?
  contentType     String?
  sizeBytes       Int?
  caption         String?
  createdByUserId String?
  createdAt       DateTime    @default(now())
  createdByUser   User?       @relation("VisitPhotoCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  visit           LoggedVisit @relation(fields: [loggedVisitId], references: [id], onDelete: Cascade)

  @@index([loggedVisitId])
  @@index([createdByUserId])
}

model WorklistItem {
  id                 String           @id @default(cuid())
  title              String
  detail             String?
  status             WorklistStatus   @default(OPEN)
  source             WorklistSource   @default(MANUAL)
  category           WorklistCategory @default(GENERAL)
  agencyId           String?
  wholesaleAccountId String?
  loggedVisitId      String?
  dueDate            DateTime?
  assignedTo         String?
  createdBy          String?
  createdByUserId    String?
  assignedToUserId   String?
  completedByUserId  String?
  cancelledByUserId  String?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  assignedToUser     User?            @relation("WorklistItemAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  cancelledByUser    User?            @relation("WorklistItemCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  completedByUser    User?            @relation("WorklistItemCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  createdByUser      User?            @relation("WorklistItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  loggedVisit        LoggedVisit?     @relation(fields: [loggedVisitId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([category])
  @@index([dueDate])
  @@index([agencyId])
  @@index([wholesaleAccountId])
  @@index([source, status, wholesaleAccountId])
  @@index([createdByUserId])
  @@index([assignedToUserId])
  @@index([completedByUserId])
  @@index([cancelledByUserId])
}
